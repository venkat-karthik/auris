# Auris Backend Environment Variables
# Copy this to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://auris:auris@localhost:5432/auris

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── AI Providers (platform master keys) ──────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
GROQ_API_KEY=gsk_...
SARVAM_API_KEY=...          # For Hindi, Telugu, Tamil
CARTESIA_API_KEY=...
ANTHROPIC_API_KEY=...

# ── Telephony ─────────────────────────────────────────────────────────────────
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_CONNECTION_ID=platform-connection-id
TELNYX_CALLER_ID=+10000000000
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...


# ── Payments (Razorpay) ───────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── Storage (MinIO for local, S3 for prod) ────────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=auris-audio

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── SMTP Email Verification ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=onboarding@auris.xyz

# ── TURN / WebRTC ─────────────────────────────────────────────────────────────
TURN_HOST=localhost
TURN_PORT=3478
TURN_SECRET=auris-turn-secret-key-for-local-development-9912

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── WhatsApp Messaging ────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=auris_whatsapp_verify_token

